{
  "name": "ghost-ops",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/run-next.mjs dev",
    "build": "node ./scripts/run-next.mjs build",
    "start": "node ./scripts/run-next.mjs start",
    "lint": "node ./scripts/run-next.mjs lint",
    "forge": "node ./scripts/run-foundry.mjs",
    "demo:contract": "node ./scripts/run-foundry.mjs script script/GhostSepoliaDemo.s.sol:DeployGhostSepoliaDemo",
    "demo:contract:deploy": "node ./scripts/run-foundry.mjs script script/GhostSepoliaDemo.s.sol:DeployGhostSepoliaDemo --broadcast",
    "demo:contract:deploy:verify": "node ./scripts/run-foundry.mjs script script/GhostSepoliaDemo.s.sol:DeployGhostSepoliaDemo --broadcast --verify --verifier etherscan",
    "demo:contract:verify": "node ./scripts/run-foundry.mjs verify-contract"
  },
  "dependencies": {
    "@0gfoundation/0g-ts-sdk": "^1.2.6",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "clsx": "^2.1.1",
    "ethers": "6.13.1",
    "next": "^14.2.30",
    "nodemailer": "^8.0.6",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
